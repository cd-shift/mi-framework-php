{
    "name": "cd-shift/mi-framework",
    "description": "Simple PHP framework inspire by Laravel",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "mi\\": "src/mi"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "mi\\Tests\\": "tests"
        }
    },
    "scripts":{
        "tests": "phpunit --color=always --testdox --display-errors --display-warnings --display-deprecations tests/"
    },
    "authors": [
        {
            "name": "Carlos Daniel M. A.",
            "email": "carlosdanielface1@hotmail.com"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    }
}
